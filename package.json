{
  "name": "@gesslar/uglier",
  "description": "Composable ESLint flat config blocks for stylistic, JSDoc, and environment presets.",
  "author": {
    "name": "gesslar",
    "url": "https://gesslar.dev"
  },
  "version": "2.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/uglier.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/types/uglier.d.ts",
      "default": "./src/uglier.js"
    }
  },
  "bin": {
    "uglier": "./src/install.js"
  },
  "files": [
    "src",
    "bin",
    "UNLICENSE.txt"
  ],
  "keywords": [
    "eslint",
    "eslintconfig",
    "style",
    "jsdoc",
    "globals",
    "404",
    "file",
    "not",
    "found",
    "cat.gif"
  ],
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "types": "node -e \"require('fs').rmSync('types',{recursive:true,force:true});\" && tsc -p tsconfig.types.json",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "update": "npx npm-check-updates -u && npm install",
    "submit": "npm publish --access public --//registry.npmjs.org/:_authToken=\"${NPM_ACCESS_TOKEN}\"",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "docs:dev": "cd docs && npm run start",
    "docs:build": "cd docs && npm run build",
    "docs:deploy": "gh workflow run deploy-docs.yml"
  },
  "license": "Unlicense",
  "engines": {
    "node": ">=24.13.0"
  },
  "dependencies": {
    "@gesslar/colours": ">=0.8.0",
    "@gesslar/toolkit": ">=4.1.0",
    "@skarab/detect-package-manager": ">=1.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-jsdoc": ">=62.8.0",
    "globals": ">=17.4.0"
  },
  "devDependencies": {
    "@gesslar/uglier": ">=2.1.0",
    "eslint": ">=10.0.3",
    "typescript": "^5.9.3"
  }
}
